{
  "name": "stylekit",
  "version": "4.1.0",
  "description": "Customize any website's appearance instantly",
  "homepage": "https://github.com/SysAdminDoc/StyleKit#readme",
  "bugs": {
    "url": "https://github.com/SysAdminDoc/StyleKit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SysAdminDoc/StyleKit.git"
  },
  "license": "MIT",
  "author": "SysAdminDoc",
  "scripts": {
    "build": "vite build",
    "build:firefox": "cross-env BROWSER=firefox vite build",
    "watch": "vite build --watch",
    "watch:firefox": "cross-env BROWSER=firefox vite build --watch",
    "start:firefox": "web-ext run --source-dir ./firefox-dist/",
    "lint": "eslint --ext .js,.ts,.vue src",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "patch-package"
  },
  "lint-staged": {
    "src/**/*.{js,ts,vue}": [
      "npm run lint:fix"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/preset-env": "^7.24.0",
    "@mozilla/readability": "^0.5.0",
    "@popperjs/core": "^2.11.8",
    "@types/chrome": "^0.0.268",
    "@types/dedent": "^0.7.2",
    "@types/lodash": "^4.17.0",
    "@types/tinycolor2": "^1.4.6",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.0",
    "bootstrap": "^5.3.0",
    "bootstrap-vue-3": "^0.5.1",
    "copy-webpack-plugin": "^12.0.0",
    "cross-env": "^7.0.3",
    "cssnano": "^7.0.0",
    "date-fns": "^3.0.0",
    "dedent": "^1.5.0",
    "deepmerge": "^4.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "eslint-plugin-vue": "^9.23.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "lodash": "^4.17.21",
    "monaco-editor": "^0.47.0",
    "patch-package": "^8.0.0",
    "postcss": "^8.4.38",
    "postcss-rem-to-pixel": "^4.1.2",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.2.0",
    "sass": "^1.72.0",
    "tinycolor2": "^1.6.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0",
    "vue": "^3.4.0",
    "vue-draggable-resizable": "^3.0.0",
    "vue-eslint-parser": "^9.4.0",
    "vue3-swatches": "^1.2.0",
    "vuex": "^4.1.0",
    "web-ext": "^7.11.0"
  }
}
